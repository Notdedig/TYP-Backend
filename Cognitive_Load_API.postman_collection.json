    {
      "name": "Calibration",
      "item": [
        {
          "name": "Start Calibration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seeedStudioIp\": \"192.168.1.100\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/calibrate/start",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "calibrate", "start"]
            }
          }
        },
        {
          "name": "Get Calibration Status",
          "request": {
