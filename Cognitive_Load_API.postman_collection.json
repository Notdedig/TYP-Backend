{
  "info": {
    "name": "Cognitive Load API",
    "description": "API endpoints for cognitive load estimation system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Heart Rate",
      "item": [
        {
          "name": "Send Heart Rate Data (ESP32)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"heartRate\": 75.5\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/heartrate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "heartrate"]
            }
          }
        },
        {
          "name": "Get Heart Rate Data",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/heartrate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "heartrate"]
            }
          }
        }
      ]
    },
    {
